			"scriptLines": [
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as integer,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as integer,",
				"          edad_maxima_dias as integer,",
				"          intervalo_minimo_dias as integer,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as decimal(5,2),",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"select1 derive(fuente_origen = \"La Paz\",",
				"          nombre_paciente = trim(nombres),",
				"          apellido_paterno = trim(primer_apellido),",
				"          apellido_materno = iif(isNull(segundo_apellido) || segundo_apellido == '', toString(null()), trim(segundo_apellido)),",
				"          sexo = iif(genero == 'Masculino', 'M', 'F'),",
				"          comunidad_indigena = iif(pueblo_indigena == 'Sí', true(), false())) ~> derivedColumn1",
				"source1 select(mapColumn(",
				"          registro_id = id_registro,",
				"          paciente_id = cod_paciente,",
				"          documento_identidad,",
				"          nombres,",
				"          primer_apellido,",
				"          segundo_apellido,",
				"          genero,",
				"          fec_nacimiento,",
				"          municipio_residencia = municipio,",
				"          pueblo_indigena,",
				"          fec_vacunacion,",
				"          vacuna_id = cod_vacuna,",
				"          desc_vacuna,",
				"          nro_dosis,",
				"          establecimiento_id = cod_establecimiento,",
				"          desc_establecimiento,",
				"          depto,",
				"          lote_vacuna = nro_lote,",
				"          temp_conservacion,",
				"          edad_dias,",
				"          via_administracion = via_aplicacion",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn1 derive(documento_numero = split(documento_identidad, ' ')[1],",
				"          documento_expedido = split(documento_identidad, ' ')[2]) ~> derivedColumn2",
				"derivedColumn2 derive(fecha_nacimiento = toDate(fec_nacimiento, 'd/M/yyyy'),",
				"          fecha_vacunacion = toDate(fec_vacunacion, 'd/M/yyyy')) ~> derivedColumn3",
				"derivedColumn3 derive(numero_dosis = toInteger(nro_dosis),",
				"          temperatura_conservacion = toDecimal(temp_conservacion, 5, 2),",
				"          edad_dias_aplicacion = toInteger(edad_dias),",
				"          fecha_carga = currentTimestamp()) ~> derivedColumn4",
				"derivedColumn4, source4 join(select1@vacuna_id == source4@vacuna_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 derive(aplicacion_oportuna = iif(edad_dias_aplicacion <= toInteger(edad_maxima_dias), true(), false())) ~> derivedColumn5",
				"derivedColumn5 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          municipio_residencia,",
				"          vacuna_id = select1@vacuna_id,",
				"          establecimiento_id,",
				"          lote_vacuna,",
				"          via_administracion = select1@via_administracion,",
				"          fuente_origen,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          comunidad_indigena,",
				"          documento_numero,",
				"          documento_expedido,",
				"          fecha_nacimiento,",
				"          fecha_vacunacion,",
				"          numero_dosis = derivedColumn4@numero_dosis,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          fecha_carga,",
				"          aplicacion_oportuna",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source2 derive(registro_id = record_id,",
				"          fuente_origen = 'Rural Movil',",
				"          paciente_id = patient_id) ~> derivedColumn6",
				"derivedColumn6 derive(documento_numero = split(patient_ci, ' ')[1],",
				"          documento_expedido = split(patient_ci, ' ')[2]) ~> derivedColumn7",
				"derivedColumn7 derive(nombre_paciente = trim(patient_name),",
				"          apellido_paterno = trim(patient_last_name_1),",
				"          apellido_materno = iif(isNull(patient_last_name_2) || patient_last_name_2 == '', toString(null()), trim(patient_last_name_2)),",
				"          sexo = patient_sex,",
				"          municipio_residencia = trim(patient_municipality),",
				"          comunidad_indigena = toBoolean(patient_indigenous)) ~> derivedColumn8",
				"derivedColumn8 derive(fecha_nacimiento = toDate(patient_birth_date, 'd/M/yyyy'),",
				"          fecha_vacunacion = toDate(vaccination_date, 'yyyy-MM-dd\\'T\\'HH:mm:ss')) ~> derivedColumn9",
				"derivedColumn9 derive(vacuna_id = vaccine_code,",
				"          numero_dosis = toInteger(toFloat(dose_number)),",
				"          establecimiento_id = facility_code,",
				"          lote_vacuna = lot_number,",
				"          temperatura_conservacion = toDecimal(storage_temp_celsius, 5, 2),",
				"          edad_dias_aplicacion = toInteger(patient_age_days),",
				"          via_administracion = administration_route,",
				"          fecha_carga = currentTimestamp()) ~> derivedColumn10",
				"derivedColumn10, source4 join(derivedColumn10@vacuna_id == source4@vacuna_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 derive(aplicacion_oportuna = iif(edad_dias_aplicacion <= toInteger(edad_maxima_dias), true(), false())) ~> derivedColumn11",
				"derivedColumn11 select(mapColumn(",
				"          registro_id,",
				"          fuente_origen,",
				"          paciente_id,",
				"          documento_numero,",
				"          documento_expedido,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_nacimiento,",
				"          fecha_vacunacion,",
				"          vacuna_id = derivedColumn10@vacuna_id,",
				"          numero_dosis = derivedColumn10@numero_dosis,",
				"          establecimiento_id,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          via_administracion = derivedColumn10@via_administracion,",
				"          fecha_carga,",
				"          aplicacion_oportuna",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"source3 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"select4 derive(fuente_origen = 'Santa Cruz',",
				"          documento_numero = split(ci_paciente, ' ')[1],",
				"          documento_expedido = split(ci_paciente, ' ')[2],",
				"          fecha_nacimiento = toDate(fecha_nacimiento, 'd/M/yyyy'),",
				"          comunidad_indigena = toBoolean(comunidad_indigena),",
				"          fecha_vacunacion = toDate(fecha_vacunacion, 'd/M/yyyy')) ~> derivedColumn12",
				"derivedColumn12 derive(numero_dosis = toInteger(numero_dosis),",
				"          temperatura_conservacion = toDecimal(temperatura_conservacion, 5, 2),",
				"          edad_dias_aplicacion = toInteger(edad_dias_aplicacion),",
				"          aplicacion_oportuna = toBoolean(aplicacion_oportuna),",
				"          fecha_carga = currentTimestamp(),",
				"          apellido_materno = iif(isNull(apellido_materno) || apellido_materno == '', toString(null()), trim(apellido_materno))) ~> derivedColumn13",
				"derivedColumn13 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion,",
				"          fuente_origen,",
				"          documento_numero,",
				"          documento_expedido,",
				"          fecha_carga",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"select2, select3 union(byName: true)~> union1",
				"union1, select5 union(byName: true)~> union2",
				"union2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          registro_id as string,",
				"          fuente_origen as string,",
				"          paciente_id as string,",
				"          documento_numero as string,",
				"          documento_expedido as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          vacuna_id as string,",
				"          numero_dosis as integer,",
				"          establecimiento_id as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias_aplicacion as integer,",
				"          aplicacion_oportuna as boolean,",
				"          via_administracion as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          registro_id,",
				"          fuente_origen,",
				"          paciente_id,",
				"          documento_numero,",
				"          documento_expedido,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion,",
				"          fecha_carga",
				"     )) ~> sink1"
			]
		}
	}
}