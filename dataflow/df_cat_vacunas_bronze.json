{
	"name": "df_cat_vacunas_bronze",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_vacunas_pai_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_cat_vacunas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as string,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as string,",
				"          edad_maxima_dias as string,",
				"          intervalo_minimo_dias as string,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as string,",
				"          condicion_especial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(vacuna_nombre = trim(vacuna_nombre),",
				"          vacuna_id = trim(vacuna_id),",
				"          enfermedad_previene = trim(enfermedad_previene),",
				"          via_administracion = trim(via_administracion),",
				"          condicion_especial = trim(condicion_especial),",
				"          sitio_aplicacion = trim(sitio_aplicacion)) ~> derivedColumn1",
				"derivedColumn1 derive(numero_dosis = toInteger(numero_dosis),",
				"          edad_minima_dias = toInteger(numero_dosis),",
				"          edad_maxima_dias = iif(isNull(edad_maxima_dias) || edad_maxima_dias == '', toInteger(0), toInteger(edad_maxima_dias))) ~> derivedColumn2",
				"derivedColumn2 derive(intervalo_minimo_dias = iif(isNull(intervalo_minimo_dias) || intervalo_minimo_dias == '', toInteger(0), toInteger(toFloat(intervalo_minimo_dias))),",
				"          dosis_ml = toDecimal(dosis_ml, 5, 2),",
				"          condicion_especial = iif(isNull(condicion_especial) || trim(condicion_especial) == '', 'No aplica', trim(condicion_especial))) ~> derivedColumn3",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          numero_dosis as integer,",
				"          dosis_descripcion as string,",
				"          edad_aplicacion_descripcion as string,",
				"          edad_minima_dias as integer,",
				"          edad_maxima_dias as integer,",
				"          intervalo_minimo_dias as integer,",
				"          via_administracion as string,",
				"          sitio_aplicacion as string,",
				"          dosis_ml as decimal(5,2),",
				"          condicion_especial as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          enfermedad_previene,",
				"          grupo_pai,",
				"          numero_dosis,",
				"          dosis_descripcion,",
				"          edad_aplicacion_descripcion,",
				"          edad_minima_dias,",
				"          edad_maxima_dias,",
				"          intervalo_minimo_dias,",
				"          via_administracion,",
				"          sitio_aplicacion,",
				"          dosis_ml,",
				"          condicion_especial",
				"     )) ~> sink1"
			]
		}
	}
}